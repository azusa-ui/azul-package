\name{azul_help}
\alias{azul_help}
\title{Overview of the azul package functions}
\usage{
azul_help()
}
\value{Invisibly \code{NULL}; called for its printed output.}
\description{
Prints a grouped list of the main azul functions with a one-line description of
each. For full help on any function use \code{?function_name}; to search, use
\code{??azul}; for package-level help use \code{?azul}.
}
\examples{
azul_help()
}
