\name{fmt_num}
\alias{fmt_num}
\title{Format a number to a fixed number of decimals}
\usage{fmt_num(x, dp = 2)}
\arguments{
\item{x}{Numeric vector.}
\item{dp}{Decimal places (default 2).}
}
\value{Character vector.}
\description{Format a number to a fixed number of decimal places.}
\examples{fmt_num(3.14159, 2)}
